# Anthropic API key — Opus 4.7 calls (transforms, anomaly detection, themes)
ANTHROPIC_API_KEY=sk-ant-...

# HTTP server port (iOS app polls this)
BENTODECK_HTTP_PORT=3737

# Where the SQLite file and any local state live
BENTODECK_DATA_DIR=./data

